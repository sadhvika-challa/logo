{
  "manifest_version": 3,
  "name": "Logo Lift",
  "version": "1.0.0",
  "description": "Detect and download logo & brand assets from any webpage.",
  "permissions": ["activeTab", "scripting", "downloads", "clipboardWrite"],
  "action": {
    "default_title": "Logo Lift",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
